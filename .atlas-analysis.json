  "keyFeatures": [
    "FastAPI-based solver server with health and notify endpoints",
    "Comprehensive data models for orders, tokens, and AMMs",
    "Support for constant-product and weighted-product AMMs",
    "Batch auction processing with customizable solver logic",
    "Docker deployment with configurable environment settings",
    "Integration with CoW Protocol orderbook and driver"
  ],
  "publicApiSurface": [
    "POST /solve - Main endpoint for receiving and solving batch auctions",
    "POST /notify - Notification endpoint for solution results",
    "GET /health - Health check endpoint",
    "BatchAuction - Core class for batch auction representation",
    "Order - Order model with execution logic",
    "Token - Token representation and info",
    "Uniswap - AMM pool representation",
    "SolverArgs - Request parameter parsing"
  ]
